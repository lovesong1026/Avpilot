APP_NAME=Avpilot
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=avpilot
POSTGRES_PASSWORD=avpilot
POSTGRES_DB=avpilot

ELASTICSEARCH_URL=http://localhost:19200
HEALTH_CHECK_TIMEOUT_SECONDS=3
STORAGE_PATH=storage
MAX_UPLOAD_SIZE_MB=25

# Security
JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Alibaba Cloud Model Studio (Bailian / DashScope)
DASHSCOPE_API_KEY=
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_CHAT_MODEL=qwen-plus
BAILIAN_VISION_MODEL=qwen-vl-plus
BAILIAN_EMBEDDING_MODEL=text-embedding-v4
BAILIAN_EMBEDDING_DIMENSIONS=1024
BAILIAN_RERANK_MODEL=qwen3-rerank
BAILIAN_WORKSPACE_ID=
BAILIAN_RERANK_BASE_URL=
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=avpilot-neo4j
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
